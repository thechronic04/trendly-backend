# -----------------------------------------------
# Trendly Backend — Environment Variables
# -----------------------------------------------
# Copy this file to ".env" for local development.
# On Railway, set these in the "Variables" tab.
# -----------------------------------------------

# --- DATABASE ---
# Leave blank for local SQLite. Railway auto-injects this when you add a Postgres plugin.
DATABASE_URL=

# --- CORS ---
# Set to your Vercel frontend URL in production to lock down the API.
# Example: https://trendly.vercel.app
# Leave blank in local dev to allow all origins.
FRONTEND_URL=

# --- APP ---
DEBUG=False
PORT=8000
